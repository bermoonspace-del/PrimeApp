<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TRIUMPH</title>
  <link rel="stylesheet" href="style.css?v=20260605-1">
  <style>
    html, body { height: 100%; margin: 0; color:#fff; font-family: Inter, Segoe UI, Roboto, Arial, sans-serif; position: relative; }
    .background-svg { position: fixed; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: -1; overflow: hidden; }
    .wrap { padding: 18px; }
    h1 { margin: 0 0 10px; font-size: 20px; }
    p { margin: 0; opacity: .8; line-height: 1.4; }
  </style>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <script>
    if (window.Telegram && window.Telegram.WebApp) {
      window.Telegram.WebApp.expand();
    }
  </script>
</head>
<body>
  <svg class="background-svg" viewBox="0 0 450 800" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
    <defs>
      <linearGradient id="bgGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#0a0a0a"/>
        <stop offset="50%" stop-color="#111111"/>
        <stop offset="100%" stop-color="#0d0d0d"/>
      </linearGradient>
      <radialGradient id="redGlow" cx="50%" cy="30%" r="45%">
        <stop offset="0%" stop-color="#c0392b" stop-opacity="0.12"/>
        <stop offset="100%" stop-color="#0a0a0a" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="bottomGlow" cx="50%" cy="90%" r="40%">
        <stop offset="0%" stop-color="#c0392b" stop-opacity="0.06"/>
        <stop offset="100%" stop-color="#0a0a0a" stop-opacity="0"/>
      </radialGradient>
      <linearGradient id="gridFade" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="white" stop-opacity="0"/>
        <stop offset="30%" stop-color="white" stop-opacity="0.5"/>
        <stop offset="60%" stop-color="white" stop-opacity="0.4"/>
        <stop offset="100%" stop-color="white" stop-opacity="0"/>
      </linearGradient>
      <mask id="gridMask">
        <rect width="450" height="800" fill="url(#gridFade)"/>
      </mask>
      <filter id="noise" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" result="noiseOut"/>
        <feColorMatrix type="saturate" values="0" in="noiseOut" result="grayNoise"/>
        <feBlend in="SourceGraphic" in2="grayNoise" mode="overlay" result="blended"/>
        <feComposite in="blended" in2="SourceGraphic" operator="in"/>
      </filter>
    </defs>
    <rect width="450" height="800" fill="url(#bgGrad)"/>
    <rect width="450" height="800" fill="url(#redGlow)"/>
    <rect width="450" height="800" fill="url(#bottomGlow)"/>
    <g mask="url(#gridMask)" opacity="0.18">
      <line x1="225" y1="320" x2="-60" y2="800" stroke="#cc2222" stroke-width="0.6"/>
      <line x1="225" y1="320" x2="30" y2="800" stroke="#cc2222" stroke-width="0.6"/>
      <line x1="225" y1="320" x2="110" y2="800" stroke="#cc2222" stroke-width="0.6"/>
      <line x1="225" y1="320" x2="170" y2="800" stroke="#cc2222" stroke-width="0.6"/>
      <line x1="225" y1="320" x2="225" y2="800" stroke="#cc2222" stroke-width="0.8"/>
      <line x1="225" y1="320" x2="280" y2="800" stroke="#cc2222" stroke-width="0.6"/>
      <line x1="225" y1="320" x2="340" y2="800" stroke="#cc2222" stroke-width="0.6"/>
      <line x1="225" y1="320" x2="420" y2="800" stroke="#cc2222" stroke-width="0.6"/>
      <line x1="225" y1="320" x2="510" y2="800" stroke="#cc2222" stroke-width="0.6"/>
      <line x1="0" y1="400" x2="450" y2="400" stroke="#cc2222" stroke-width="0.5"/>
      <line x1="0" y1="460" x2="450" y2="460" stroke="#cc2222" stroke-width="0.5"/>
      <line x1="0" y1="510" x2="450" y2="510" stroke="#cc2222" stroke-width="0.5"/>
      <line x1="0" y1="555" x2="450" y2="555" stroke="#cc2222" stroke-width="0.5"/>
      <line x1="0" y1="595" x2="450" y2="595" stroke="#cc2222" stroke-width="0.4"/>
      <line x1="0" y1="630" x2="450" y2="630" stroke="#cc2222" stroke-width="0.4"/>
      <line x1="0" y1="662" x2="450" y2="662" stroke="#cc2222" stroke-width="0.3"/>
      <line x1="0" y1="690" x2="450" y2="690" stroke="#cc2222" stroke-width="0.3"/>
      <line x1="0" y1="715" x2="450" y2="715" stroke="#cc2222" stroke-width="0.3"/>
      <line x1="0" y1="738" x2="450" y2="738" stroke="#cc2222" stroke-width="0.2"/>
      <line x1="0" y1="758" x2="450" y2="758" stroke="#cc2222" stroke-width="0.2"/>
      <line x1="0" y1="776" x2="450" y2="776" stroke="#cc2222" stroke-width="0.2"/>
    </g>
    <g opacity="0.35">
      <line x1="60" y1="160" x2="130" y2="310" stroke="#cc2222" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="76" y1="160" x2="146" y2="310" stroke="#cc2222" stroke-width="1" stroke-linecap="round"/>
    </g>
    <g opacity="0.35">
      <line x1="390" y1="160" x2="320" y2="310" stroke="#cc2222" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="374" y1="160" x2="304" y2="310" stroke="#cc2222" stroke-width="1" stroke-linecap="round"/>
    </g>
    <line x1="80" y1="72" x2="370" y2="72" stroke="#cc2222" stroke-width="0.8" opacity="0.4"/>
    <line x1="0" y1="728" x2="450" y2="728" stroke="#cc2222" stroke-width="0.8" opacity="0.25"/>
    <g stroke="#cc2222" stroke-width="1.2" fill="none" opacity="0.5">
      <polyline points="18,18 18,48 48,48"/>
    </g>
    <g stroke="#cc2222" stroke-width="1.2" fill="none" opacity="0.5">
      <polyline points="432,18 432,48 402,48"/>
    </g>
    <g stroke="#cc2222" stroke-width="1.2" fill="none" opacity="0.3">
      <polyline points="18,782 18,752 48,752"/>
    </g>
    <g stroke="#cc2222" stroke-width="1.2" fill="none" opacity="0.3">
      <polyline points="432,782 432,752 402,752"/>
    </g>
    <rect width="450" height="800" fill="#1a1a1a" opacity="0.04" filter="url(#noise)"/>
  </svg>
  <div id="pcs"></div>
  <div id="map-message" class="map-message" hidden></div>
  <div class="wrap">
    <h1>TRIUMPH</h1>

  </div>
  <script src="TRIUMPHapp.js?v=20260605-1"></script>
</body>
</html>

